# Environment
NODE_ENV=development

# Application
PORT=5000

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:password123@localhost:5432/kit_canteen
POSTGRES_DB=kit_canteen
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MongoDB Database
MONGODB_URL=mongodb://admin:password123@localhost:27017/kit_canteen?authSource=admin
MONGO_DB=kit_canteen
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password123
MONGO_HOST=localhost
MONGO_PORT=27017

# Production Database URLs (for deployment)
# DATABASE_URL_PROD=postgresql://user:pass@prod-host:5432/kit_canteen
# MONGODB_URL_PROD=mongodb://user:pass@prod-host:27017/kit_canteen

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# Authentication & Security
JWT_SECRET=your-jwt-secret-key-here
SESSION_SECRET=your-session-secret-here

# External Services (add as needed)
# FIREBASE_PROJECT_ID=your-firebase-project
# STRIPE_SECRET_KEY=sk_test_...
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...