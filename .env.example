# Environment
NODE_ENV=development

# Application
PORT=5000

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:password123@localhost:5432/kit_canteen
POSTGRES_DB=kit_canteen
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MongoDB Database
MONGODB_URL=mongodb://admin:password123@localhost:27017/kit_canteen?authSource=admin
MONGO_DB=kit_canteen
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password123
MONGO_HOST=localhost
MONGO_PORT=27017

# Production Database URLs (for deployment)
# DATABASE_URL_PROD=postgresql://user:pass@prod-host:5432/kit_canteen
# MONGODB_URL_PROD=mongodb://user:pass@prod-host:27017/kit_canteen

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# Authentication & Security
JWT_SECRET=your-jwt-secret-key-here
SESSION_SECRET=your-session-secret-here

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project.iam.gserviceaccount.com

# Firebase Client Configuration (for frontend)
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# PhonePe Payment Gateway Configuration
PHONEPE_MERCHANT_ID=your-merchant-id
PHONEPE_SALT_KEY=your-salt-key
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=SANDBOX
PHONEPE_HOST_URL=https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_CALLBACK_URL=http://localhost:5000/api/phonepe/callback
PHONEPE_REDIRECT_URL=http://localhost:5000/payment-success

# Additional External Services
# STRIPE_SECRET_KEY=sk_test_...
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...