# KIT Canteen App Environment Variables

# ========================================
# DATABASE CONFIGURATION
# ========================================

# PostgreSQL Database (Required for user authentication)
DATABASE_URL=postgresql://username:password@localhost:5432/kit_canteen

# MongoDB Configuration (Choose one option)
# Option 1: MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/kit-canteen?retryWrites=true&w=majority

# Option 2: Local MongoDB (Development)
MONGODB_URI=mongodb://localhost:27017/kit-canteen

# Option 3: Custom MongoDB Instance
# MONGODB_URI=mongodb://username:password@host:port/database

# Alternative environment-specific variables (optional)
# MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/kit-canteen?retryWrites=true&w=majority
# MONGODB_LOCAL_URI=mongodb://localhost:27017/kit-canteen-dev

# ========================================
# APPLICATION CONFIGURATION
# ========================================

# Environment
NODE_ENV=development

# Server Configuration
PORT=3000

# ========================================
# FIREBASE AUTHENTICATION
# ========================================

# Firebase Web App Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ========================================
# PAYMENT GATEWAY (PhonePe)
# ========================================

# PhonePe Test Configuration
PHONEPE_MERCHANT_ID=PGTESTPAYUAT86
PHONEPE_SALT_KEY=your_phonepe_salt_key
PHONEPE_SALT_INDEX=1
PHONEPE_ENVIRONMENT=sandbox

# ========================================
# SESSION CONFIGURATION
# ========================================

SESSION_SECRET=your_very_long_random_session_secret_here_minimum_32_characters