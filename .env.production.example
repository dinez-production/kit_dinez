# Production Environment Configuration
NODE_ENV=production
PORT=5000

# PostgreSQL Production Database
DATABASE_URL=postgresql://username:password@prod-host:5432/kit_canteen_prod
POSTGRES_DB=kit_canteen_prod
POSTGRES_USER=kit_canteen_user
POSTGRES_PASSWORD=secure_production_password
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432

# MongoDB Production Database  
MONGODB_URL=mongodb://username:password@prod-host:27017/kit_canteen_prod?authSource=admin
MONGO_DB=kit_canteen_prod
MONGO_ROOT_USER=kit_canteen_mongo_user
MONGO_ROOT_PASSWORD=secure_mongo_password
MONGO_HOST=your-mongo-host
MONGO_PORT=27017

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/var/backups/kit-canteen

# Security
JWT_SECRET=your-ultra-secure-jwt-secret-key-min-64-chars
SESSION_SECRET=your-ultra-secure-session-secret-key-min-32-chars

# Health Checks
HEALTH_CHECK_URL=https://your-domain.com

# External Services
# FIREBASE_PROJECT_ID=your-firebase-project-id
# STRIPE_SECRET_KEY=sk_live_...
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...

# Monitoring & Logging
# SENTRY_DSN=https://...
# LOG_LEVEL=info