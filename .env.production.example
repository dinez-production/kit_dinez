# Production Environment Configuration
NODE_ENV=production
PORT=5000

# PostgreSQL Production Database
DATABASE_URL=postgresql://username:password@prod-host:5432/kit_canteen_prod
POSTGRES_DB=kit_canteen_prod
POSTGRES_USER=kit_canteen_user
POSTGRES_PASSWORD=secure_production_password
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432

# MongoDB Production Database  
MONGODB_URL=mongodb://username:password@prod-host:27017/kit_canteen_prod?authSource=admin
MONGO_DB=kit_canteen_prod
MONGO_ROOT_USER=kit_canteen_mongo_user
MONGO_ROOT_PASSWORD=secure_mongo_password
MONGO_HOST=your-mongo-host
MONGO_PORT=27017

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/var/backups/kit-canteen

# Security
JWT_SECRET=your-ultra-secure-jwt-secret-key-min-64-chars
SESSION_SECRET=your-ultra-secure-session-secret-key-min-32-chars

# Health Checks
HEALTH_CHECK_URL=https://your-domain.com

# Firebase Production Configuration
FIREBASE_PROJECT_ID=your-prod-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-prod-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-prod-private-key-here\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-prod-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-prod-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-prod-project.iam.gserviceaccount.com

# Firebase Client Production Configuration
VITE_FIREBASE_API_KEY=your-prod-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-prod-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-prod-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-prod-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# PhonePe Production Configuration
PHONEPE_MERCHANT_ID=your-production-merchant-id
PHONEPE_SALT_KEY=your-production-salt-key
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=PRODUCTION
PHONEPE_HOST_URL=https://api.phonepe.com/apis/hermes
PHONEPE_CALLBACK_URL=https://your-domain.com/api/phonepe/callback
PHONEPE_REDIRECT_URL=https://your-domain.com/payment-success

# Additional External Services
# STRIPE_SECRET_KEY=sk_live_...
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...

# Monitoring & Logging
# SENTRY_DSN=https://...
# LOG_LEVEL=info